# Copy this file to .env and fill in values

# ── Storage ───────────────────────────────────────────────────────────────────
# FastF1 caches raw session data locally (Race + Qualifying, 2018-2024 ≈ 15-20 GB).
# Default: data/raw/fastf1_cache/ inside the project directory.
# Override with an absolute path if your primary drive is low on space, e.g.:
#   FASTF1_CACHE_DIR=D:\f1_cache
# Leave blank to use the default.
FASTF1_CACHE_DIR=

# ── Data settings ─────────────────────────────────────────────────────────────
# First season to load via Jolpica historical API
# 2014 = start of the turbo-hybrid era (first complete regulation cycle)
HISTORICAL_START_YEAR=2014
# Last season to load via Jolpica (FastF1 takes over at FASTF1_START_YEAR)
# 2014–2017 = 4 seasons, ~85 races from Jolpica
HISTORICAL_END_YEAR=2017
# First season to load from FastF1 (richer telemetry + weather data available)
FASTF1_START_YEAR=2018
# Last season to load from FastF1
FASTF1_END_YEAR=2024
# Sessions to download per race weekend (comma-separated, no spaces)
# Qualifying and Race are sufficient for the feature set. FP sessions add
# useful free-practice pace data but cost ~3x the disk and download time.
FASTF1_SESSIONS=Qualifying,Race

# ── Model settings ────────────────────────────────────────────────────────────
# Number of recent races used in rolling-average features
ROLLING_WINDOW=5
# Walk-forward: minimum training size before first prediction (number of races)
MIN_TRAIN_RACES=50
# Sample weight decay rate for older seasons (0 = no decay, 0.2 = 20% per year)
SAMPLE_WEIGHT_DECAY=0.15

# ── Weather feature settings ─────────────────────────────────────────────────
# Weather is aggregated to race-level means and attached as ML features.
# Included: Rainfall (binary), TrackTemp, AirTemp, WindSpeed, Humidity
# Excluded: WindDirection (circuit-geometry-dependent), Pressure (redundant
#           with per-circuit altitude constant already captured by circuit ID)
INCLUDE_WEATHER=true

# ── Monte Carlo settings ──────────────────────────────────────────────────────
# Number of simulation runs for each race
MONTE_CARLO_N_RUNS=10000
# Random seed for reproducibility (set to empty string to disable)
RANDOM_SEED=42
